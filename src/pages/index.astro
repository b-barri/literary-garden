---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import { siteConfig } from "~/site.config";
---

<BaseLayout title={siteConfig.siteTitle} fullBleed={true}>
  <div class="page watercolor-paper">
    <Nav currentPath={Astro.url.pathname} />

    <main class="paper">
      <div class="wisteria" aria-hidden="true">
        <img src="/wisteria-header.png" alt="" loading="eager" fetchpriority="high" />
      </div>

      <div class="masthead">
        <div class="seal" aria-hidden="true">
          <img src="/cameo.png" alt="" loading="eager" />
        </div>

        <h1 class="title">{siteConfig.siteTitle}</h1>
        <p class="subtitle">a gentle reader's notes</p>
        <hr class="rule" />
      </div>

      <article class="letter">
        <p class="salutation"><em>Dearest Gentle Reader,</em></p>

        <p>
          It is the conviction of this author that every soul is born
          into an <em>intellectual orbit</em> — a quiet circumference of
          thought inherited from one's family, one's schooling, the
          small city of one's youth. To live is to widen that orbit.
          One may do so through travel, of course, though such
          journeys are dear and infrequent. But there is a humbler
          path, available to any person with a lamp and an hour:
          reading.
        </p>

        <p>
          A book is a letter from a stranger who has lived what you
          have not. Open enough of them and your orbit swells; the
          world presses in; you become, by degrees, a person of
          wider weather.
        </p>

        <p>
          What follows — these pressed vocabularies, these daily
          practisings — is merely the gardener's log of my own
          widening. You are most welcome to observe.
        </p>

        <p class="signoff">
          <em>Yours Truly,</em><br />
          <span class="signature">{siteConfig.ownerName}</span>
        </p>
      </article>

      <nav class="doorways" aria-label="enter the garden">
        <a href="/practice" class="door">
          <span class="door-label">daily practice</span>
          <span class="door-hint">words in their bed — a small handful a day</span>
        </a>
        <a href="/garden" class="door">
          <span class="door-label">the garden</span>
          <span class="door-hint">what has been pressed and what is in bloom</span>
        </a>
      </nav>

      <div class="flourish" aria-hidden="true">
        <span></span><span class="ornament">✦</span><span></span>
      </div>

      <figure class="hero-band" aria-label="above the clouds, always reading">
        <img
          class="hero-poster"
          src="/garden-hero-poster.jpg"
          alt=""
          aria-hidden="true"
        />
        <video
          class="hero-video"
          autoplay
          loop
          muted
          playsinline
          webkit-playsinline="true"
          disablepictureinpicture
          preload="auto"
          poster="/garden-hero-poster.jpg"
        >
          <!-- MP4 first so iOS Safari picks a codec it plays reliably on
               autoplay. iOS's fallback from a WebM first-source to MP4
               second-source is unreliable in autoplay-muted mode, and we
               end up with a play-button overlay instead of silent play.
               Chrome / Firefox still prefer WebM when listed second via
               MIME type + codec parameters — no regression on desktop. -->
          <source src="/garden-hero.mp4" type="video/mp4" />
          <source src="/garden-hero.webm" type="video/webm" />
        </video>
        <div class="hero-veil"></div>
        <figcaption class="hero-caption">above the clouds, always reading</figcaption>
      </figure>

      <footer class="foot">
        <p>
          everything here lives in <em>your</em> browser.
          nothing leaves this device.
        </p>
      </footer>
    </main>
  </div>
</BaseLayout>

<style>
  /* .page sizing + the shared .watercolor-paper class (in global.css) paint the surface */
  .page {
    min-height: 100dvh;
  }

  /* Paper card — translucent so the watercolor washes bleed through the edges */
  .paper {
    max-width: 48rem;
    margin: 1.5rem auto 0;
    position: relative;
    background: oklch(0.97 0.02 85 / 0.78);
    padding: 0 2.5rem 3rem;
    border: 1px solid oklch(0.82 0.04 195 / 0.35);
    box-shadow:
      0 1px 0 oklch(0.82 0.04 195 / 0.5),
      0 18px 44px oklch(0.22 0.02 250 / 0.08);
    backdrop-filter: blur(1px);
    overflow: hidden;
  }

  /* Wisteria drape — fills paper width, natural aspect, multiply-blended onto the paper */
  .wisteria {
    margin: 0 -2.5rem 0.5rem;
    aspect-ratio: 2912 / 1632;
    overflow: hidden;
    position: relative;
  }
  .wisteria img {
    width: 100%;
    height: 100%;
    display: block;
    mix-blend-mode: multiply;
    object-fit: cover;
    object-position: center top;
  }

  .masthead {
    text-align: center;
    margin-top: -3rem;
    position: relative;
    z-index: 2;
  }
  .seal {
    width: 84px;
    height: 84px;
    margin: 0 auto 0.75rem;
    border-radius: 50%;
    background: var(--color-cream);
    box-shadow: 0 2px 10px oklch(0.22 0.02 250 / 0.14);
    overflow: hidden;
    display: grid;
    place-items: center;
  }
  .seal img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .title {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: clamp(2rem, 5.5vw, 3.2rem);
    color: var(--color-ink);
    line-height: 1.05;
    margin: 0;
    letter-spacing: -0.01em;
  }
  .subtitle {
    font-family: var(--font-display);
    font-style: normal;
    text-transform: uppercase;
    letter-spacing: 0.32em;
    font-size: 0.78rem;
    color: var(--color-sage-700);
    margin: 0.5rem 0 0;
  }
  .rule {
    border: none;
    border-top: 1px solid var(--color-ink);
    margin: 1.5rem auto 0;
    max-width: 26rem;
    opacity: 0.55;
  }

  /* The dotted-border letter */
  .letter {
    margin: 2rem 0 1.5rem;
    padding: 1.75rem 1.5rem;
    border: 1px dashed oklch(0.22 0.02 250 / 0.35);
    border-radius: 3px;
    font-family: var(--font-letter);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-ink);
    background: oklch(0.97 0.025 80);
  }
  .letter p { margin: 0 0 1.1rem; }
  .letter p:last-child { margin-bottom: 0; }
  .salutation { font-size: 1.15rem; }
  .signoff {
    margin-top: 1.5rem;
    font-size: 1.05rem;
    line-height: 1.4;
  }
  .signature {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.6rem;
    color: var(--color-sage-900);
  }

  /* Two doorways into the garden */
  .doorways {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }
  .door {
    display: block;
    padding: 1.25rem 1.25rem;
    background: var(--color-cream);
    border: 1px solid oklch(0.62 0.14 300 / 0.3);
    border-radius: 0.5rem;
    text-decoration: none;
    color: var(--color-ink);
    transition: border-color 160ms, transform 160ms, box-shadow 160ms;
  }
  .door:hover {
    border-color: var(--color-wisteria-500);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px oklch(0.62 0.14 300 / 0.12);
  }
  .door-label {
    display: block;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--color-sage-900);
    margin-bottom: 0.25rem;
  }
  .door-hint {
    font-size: 0.82rem;
    color: var(--color-sepia);
    line-height: 1.4;
  }

  /* Flourish — structural styles live in global.css (.flourish).
     Only the page-specific placement lives here. */
  .flourish {
    margin: 2.25rem auto 1.25rem;
    max-width: 22rem;
  }

  /* Cinematic band — now inside the paper, framed as a tipped-in illustration;
     honours the video's native 16:9 so nothing crops */
  .hero-band {
    position: relative;
    width: 100%;
    margin: 0 auto;
    aspect-ratio: 1280 / 714;
    overflow: hidden;
    background: transparent;
    border-radius: 2px;
  }
  .hero-poster,
  .hero-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }
  .hero-poster { z-index: 1; }
  .hero-video { z-index: 2; }
  .hero-veil { z-index: 3; }
  .hero-caption { z-index: 4; }
  /* Four-corner watercolor fade — softens the rectangle into the paper */
  .hero-veil {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 85% 80% at 50% 50%,
        transparent 50%,
        var(--color-cream) 100%),
      linear-gradient(to bottom,
        transparent 0%,
        transparent 70%,
        oklch(0.22 0.02 250 / 0.18) 100%);
    pointer-events: none;
    mix-blend-mode: normal;
  }
  .hero-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 2rem;
    text-align: center;
    color: oklch(0.97 0.02 85);
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1rem, 2.2vw, 1.3rem);
    letter-spacing: 0.04em;
    text-shadow: 0 1px 6px oklch(0.22 0.02 250 / 0.55);
  }

  /* Closing whisper — sits inside the paper, right after the illustration */
  .foot {
    margin: 1.25rem 0 0;
    padding: 0;
    text-align: center;
    color: var(--color-sepia);
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
  }
  .foot p { margin: 0; }

  /* Mobile — priority use case */
  @media (max-width: 640px) {
    .paper {
      margin: 0.75rem 0.75rem 0;
      padding: 0 1.25rem 2rem;
      border-radius: 2px;
    }
    .wisteria {
      margin: 0 -1.25rem 0.25rem;
    }
    .masthead { margin-top: -2rem; }
    .seal { width: 68px; height: 68px; }
    .letter {
      padding: 1.25rem 1rem;
      font-size: 1rem;
      line-height: 1.7;
    }
    .salutation { font-size: 1.1rem; }
    .signature { font-size: 1.4rem; }

    .doorways {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .door { padding: 1rem 1.1rem; }
    .door-label { font-size: 1.2rem; }

    .flourish { margin: 1.75rem auto 1rem; max-width: 16rem; }
    .hero-caption { bottom: 1.25rem; }
  }

  /* Reduced-motion — pause the video, poster persists */
  @media (prefers-reduced-motion: reduce) {
    .hero-video { display: none; }
    .hero-band {
      background: url("/garden-hero-poster.jpg") center / cover no-repeat;
    }
  }
</style>
