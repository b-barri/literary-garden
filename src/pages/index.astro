---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Practice from "~/components/Practice.svelte";
import { getCollection } from "astro:content";

// Read definitions directly (not a content collection — keyed by word id map).
// Fails soft if the file hasn't been generated yet.
let definitions: Record<string, any> = {};
try {
  const mod = await import("../../data/processed/definitions.json");
  definitions = (mod.default ?? mod) as Record<string, any>;
} catch {
  // definitions.json not yet generated — run `pnpm seed` first
}

const wordEntries = await getCollection("words");
const bookEntries = await getCollection("books");

const allWords = wordEntries.map((e) => e.data);
const books = bookEntries.map((e) => e.data);
---

<BaseLayout>
  <header class="mb-10">
    <p class="text-sm uppercase tracking-[0.2em] text-sage-700">a literary garden</p>
    <h1 class="mt-1 text-5xl text-sage-900">words bed</h1>
    <nav class="mt-4 flex gap-4 text-sm text-sage-700">
      <a href="/" class="font-medium">practice</a>
      <span class="text-sepia">·</span>
      <a href="/album" class="hover:text-sage-900">pressed album</a>
    </nav>
  </header>

  <Practice client:only="svelte" {allWords} {books} {definitions} />

  <footer class="mt-16 pt-8 border-t border-sage-100 text-xs text-sage-700 text-center">
    <p>phase 3 of 4 &middot; state persists in localStorage &middot; nothing leaves this device</p>
  </footer>
</BaseLayout>
