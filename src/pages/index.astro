---
import BaseLayout from "~/layouts/BaseLayout.astro";
import WordCard from "~/components/WordCard.svelte";
import { getCollection } from "astro:content";
import { assignIllustration, illustrationSvg } from "~/lib/illustration";

const words = await getCollection("words");
const books = await getCollection("books");

const booksById = new Map(books.map((b) => [b.data.id, b.data]));

// Phase 2: render all seedlings as interactive cards in a grid.
// Phase 3 will replace this with a daily-practice queue (due reviews + 5 new/day).
const sorted = [...words].sort((a, b) => a.data.word.localeCompare(b.data.word));

const cards = sorted.map(({ data: word }) => {
  const primary = booksById.get(word.primaryBookId);
  return {
    id: word.id,
    word: word.word,
    stem: word.stem,
    lang: word.lang,
    lookups: word.lookups,
    bookTitle: primary?.title ?? "",
    bookAuthors: primary?.authors ?? "",
    illustrationSvg: illustrationSvg(assignIllustration(word.id)),
  };
});
---

<BaseLayout>
  <header class="mb-10">
    <p class="text-sm uppercase tracking-[0.2em] text-sage-700">a literary garden</p>
    <h1 class="mt-1 text-5xl text-sage-900">words bed</h1>
    <p class="mt-3 text-sepia italic">
      {cards.length} seedlings &middot; {books.length} books &middot; phase 2 preview
    </p>
    <details class="mt-4 text-sm text-sage-700">
      <summary class="cursor-pointer">how to tend</summary>
      <div class="mt-2 pl-4 space-y-1 text-ink/70">
        <p>tap a card (or press <kbd class="bg-sage-50 px-1 rounded">space</kbd>) to flip it.</p>
        <p>on the back, rate: <kbd class="bg-sage-50 px-1 rounded">1</kbd> didn&rsquo;t know &middot; <kbd class="bg-sage-50 px-1 rounded">2</kbd> blurry &middot; <kbd class="bg-sage-50 px-1 rounded">3</kbd> knew it.</p>
        <p>seedlings bloom on first successful review &middot; after 21 days of proven memory, they press.</p>
      </div>
    </details>
  </header>

  <section class="grid grid-cols-2 md:grid-cols-3 gap-5">
    {
      cards.map((c) => (
        <WordCard
          client:visible
          wordId={c.id}
          word={c.word}
          stem={c.stem}
          lang={c.lang}
          lookups={c.lookups}
          bookTitle={c.bookTitle}
          bookAuthors={c.bookAuthors}
          illustrationSvg={c.illustrationSvg}
        />
      ))
    }
  </section>

  <footer class="mt-16 pt-8 border-t border-sage-100 text-xs text-sage-700 text-center">
    <p>phase 2 of 4 &middot; state persists in localStorage &middot; nothing leaves this device</p>
  </footer>
</BaseLayout>
