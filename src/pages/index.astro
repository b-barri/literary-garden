---
import BaseLayout from "~/layouts/BaseLayout.astro";
---

<BaseLayout>
  <header class="mb-8">
    <h1 class="text-4xl text-sage-900">Literary Garden</h1>
    <p class="mt-2 text-sepia italic">a seedling</p>
  </header>
  <section>
    <p class="text-ink/70">
      Your words bed will grow here. Run <code class="font-mono text-sm bg-sage-50 px-1.5 py-0.5 rounded">pnpm&nbsp;import</code> to plant it.
    </p>
  </section>
</BaseLayout>
