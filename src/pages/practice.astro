---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Practice from "~/components/Practice.svelte";
import { getCollection } from "astro:content";

let definitions: Record<string, any> = {};
try {
  const mod = await import("../../data/processed/definitions.json");
  definitions = (mod.default ?? mod) as Record<string, any>;
} catch {
  // definitions.json not yet generated — run `pnpm seed` first
}

const wordEntries = await getCollection("words");
const bookEntries = await getCollection("books");

const allWords = wordEntries.map((e) => e.data);
const books = bookEntries.map((e) => e.data);
---

<BaseLayout title="Practice · Bhavya's Literary Garden" fullBleed={true}>
  <div class="page watercolor-paper">
    <Nav currentPath={Astro.url.pathname} />

    <div class="practice-inner">
      <div class="wisteria-ribbon" aria-hidden="true">
        <img src="/wisteria-header.png" alt="" loading="eager" />
      </div>

      <header class="page-head">
        <p class="eyebrow">daily practice</p>
        <h1>words bed</h1>
        <p class="subtitle">a small handful a day — the rest waits, patient.</p>
      </header>

      <div class="flourish header-flourish" aria-hidden="true">
        <span></span><span class="ornament">✦</span><span></span>
      </div>

      <Practice client:only="svelte" {allWords} {books} {definitions} />
    </div>
  </div>
</BaseLayout>

<style>
  .page { min-height: 100dvh; }

  .practice-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
    position: relative;
  }

  /* Top-right wisteria sprig — small, clipped, ribbon-style */
  .wisteria-ribbon {
    position: absolute;
    top: 0;
    right: 0;
    width: clamp(64px, 12vw, 110px);
    aspect-ratio: 1 / 1.2;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    opacity: 0.7;
  }
  .wisteria-ribbon img {
    width: 260%;
    height: auto;
    display: block;
    margin-left: -160%;
    mix-blend-mode: multiply;
  }

  .header-flourish {
    margin: 0.5rem auto 2rem;
    max-width: 18rem;
  }

  .page-head {
    text-align: center;
    margin: 2rem 0 0.5rem;
    position: relative;
    z-index: 1;
  }
  .eyebrow {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-sage-700);
    letter-spacing: 0.08em;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    color: var(--color-sage-900);
    margin: 0.25rem 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-sepia);
    max-width: 32rem;
    margin: 0 auto;
  }
  @media (max-width: 640px) {
    .practice-inner { padding: 0 1rem 2rem; }
    .page-head { margin: 1rem 0 0.5rem; }
    .header-flourish { margin: 0.25rem auto 1rem; }
  }
  @media (max-width: 420px) {
    .practice-inner { padding: 0 0.75rem 2rem; }
    .page-head { margin: 0.75rem 0 0.5rem; }
  }
</style>
