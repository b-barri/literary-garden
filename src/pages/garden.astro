---
import BaseLayout from "~/layouts/BaseLayout.astro";
import Nav from "~/components/Nav.astro";
import Garden from "~/components/Garden.svelte";
import { getCollection } from "astro:content";

const wordEntries = await getCollection("words");
const bookEntries = await getCollection("books");

const allWords = wordEntries.map((e) => e.data);
const books = bookEntries.map((e) => e.data);
---

<BaseLayout title="Garden · Bhavya's Literary Garden" fullBleed={true}>
  <div class="page watercolor-paper">
    <Nav currentPath={Astro.url.pathname} />

    <div class="garden-inner">
      <header class="page-head">
        <p class="eyebrow">your literary garden</p>
        <h1>the garden</h1>
        <p class="subtitle">
          each session plants something. watch the field grow across days, weeks, months, years.
        </p>
      </header>

      <div class="flourish header-flourish" aria-hidden="true">
        <span></span><span class="ornament">✦</span><span></span>
      </div>

      <Garden client:only="svelte" {allWords} {books} />
    </div>
  </div>
</BaseLayout>

<style>
  .page { min-height: 100dvh; }

  .garden-inner {
    max-width: 48rem;
    margin: 0 auto;
    padding: 0 1.5rem 3rem;
    position: relative;
  }

  .header-flourish {
    margin: 0.5rem auto 1rem;
    max-width: 18rem;
  }

  .page-head {
    text-align: center;
    margin: 2rem 0 0.5rem;
  }
  .eyebrow {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-sage-700);
    letter-spacing: 0.08em;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2rem, 6vw, 3rem);
    color: var(--color-sage-900);
    margin: 0.25rem 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-sepia);
    max-width: 32rem;
    margin: 0 auto;
    line-height: 1.5;
  }
  @media (max-width: 420px) {
    .page-head { margin: 1.25rem 0 1rem; }
    .garden-inner { padding: 0 1rem 2rem; }
  }
</style>
