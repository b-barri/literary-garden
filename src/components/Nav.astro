---
import { siteConfig } from "~/site.config";

interface Props {
  currentPath: string;
}
const { currentPath } = Astro.props;

const links = [
  { href: "/", label: "the papers" },
  { href: "/practice", label: "practice" },
  { href: "/garden", label: "garden" },
  { href: "/scrapbook", label: "scrapbook" },
  { href: "/about", label: "about" },
];

function isActive(href: string) {
  if (href === "/") return currentPath === "/" || currentPath === "";
  return currentPath.startsWith(href);
}
---

<nav class="site-nav" aria-label="primary">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label={`${siteConfig.siteTitle} — home`}>
      <span class="cameo" aria-hidden="true">
        <img src="/cameo.png" alt="" />
      </span>
      <span class="wordmark">
        <span class="wordmark-main">literary garden</span>
        <span class="wordmark-sub">a gentle reader's notes</span>
      </span>
    </a>

    <ol class="nav-links">
      {links.map((l, i) => (
        <>
          <li class:list={[{ active: isActive(l.href) }]}>
            <a href={l.href}>{l.label}</a>
          </li>
          {i < links.length - 1 && (
            <li class="sep" aria-hidden="true">✦</li>
          )}
        </>
      ))}
    </ol>
  </div>
</nav>

<style>
  .site-nav {
    border-bottom: 1px solid oklch(0.72 0.08 70 / 0.22);
    background: linear-gradient(
      180deg,
      oklch(0.97 0.02 85 / 0.55) 0%,
      oklch(0.97 0.02 85 / 0) 100%
    );
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
  }

  .nav-inner {
    max-width: 52rem;
    margin: 0 auto;
    padding: 0.9rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  /* --- Brand (left) --- */
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: inherit;
    flex: 0 0 auto;
    transition: opacity 160ms;
  }
  .brand:hover { opacity: 0.8; }
  .brand:focus-visible {
    outline: 2px solid oklch(0.62 0.14 300 / 0.5);
    outline-offset: 4px;
    border-radius: 2px;
  }

  .cameo {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-cream);
    box-shadow:
      inset 0 0 0 1px oklch(0.72 0.08 70 / 0.4),
      0 1px 3px oklch(0.22 0.02 250 / 0.12);
    overflow: hidden;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
  }
  .cameo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
  }

  .wordmark {
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    line-height: 1;
  }
  .wordmark-main {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: 1.05rem;
    color: var(--color-sage-900);
    letter-spacing: 0.005em;
  }
  .wordmark-sub {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.65rem;
    color: var(--color-sepia);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  /* --- Link list (right) --- */
  .nav-links {
    display: flex;
    gap: 0.8rem;
    align-items: baseline;
    list-style: none;
    padding: 0;
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-sage-700);
    flex: 0 0 auto;
  }
  .nav-links a {
    color: inherit;
    text-decoration: none;
    padding: 0.2rem 0.1rem 0.35rem;
    position: relative;
    transition: color 140ms;
  }
  .nav-links a:hover { color: var(--color-sage-900); }
  .nav-links a:focus-visible {
    outline: 2px solid oklch(0.62 0.14 300 / 0.5);
    outline-offset: 3px;
    border-radius: 2px;
  }
  .nav-links .active a {
    color: var(--color-sage-900);
  }
  /* Gradient hairline under the active link — fades in from both ends */
  .nav-links .active a::after {
    content: "";
    position: absolute;
    left: 0.1rem;
    right: 0.1rem;
    bottom: 0.1rem;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      oklch(0.62 0.08 145 / 0.75) 20%,
      oklch(0.45 0.07 145) 50%,
      oklch(0.62 0.08 145 / 0.75) 80%,
      transparent 100%
    );
  }
  /* Small fleur above the active link — subtle signal */
  .nav-links .active a::before {
    content: "";
    position: absolute;
    left: 50%;
    top: -6px;
    transform: translateX(-50%);
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--color-sage-700);
    opacity: 0.5;
  }

  .nav-links .sep {
    color: oklch(0.72 0.08 70 / 0.55);
    font-size: 0.55rem;
    transform: translateY(-3px);
    font-style: normal;
    letter-spacing: 0;
  }

  /* --- Mobile --- */
  @media (max-width: 640px) {
    .nav-inner {
      padding: 0.75rem 1rem;
      gap: 0.75rem;
    }
    .cameo { width: 32px; height: 32px; }
    .wordmark-main { font-size: 1rem; }
    .wordmark-sub { display: none; }
    .nav-links { gap: 0.6rem; font-size: 0.95rem; }
    .nav-links .sep { font-size: 0.55rem; }
  }
  /* Very narrow: drop the brand text entirely, keep cameo + nav */
  @media (max-width: 420px) {
    .wordmark-main { display: none; }
    .nav-inner { gap: 0.5rem; }
  }
</style>
