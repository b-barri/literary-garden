{
  "name": "literary-garden",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "dev:host": "astro dev --host",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "seed": "tsx scripts/import.ts",
    "seed:refresh-covers": "tsx scripts/import.ts --refresh-covers",
    "seed:refresh-definitions": "tsx scripts/import.ts --refresh-definitions",
    "seed:refresh": "tsx scripts/import.ts --refresh",
    "seed:offline": "tsx scripts/import.ts --offline",
    "reseed": "tsx scripts/import.ts && rm -rf .astro && echo '✓ reseeded. restart pnpm dev to pick up changes.'",
    "prepare": "simple-git-hooks",
    "deploy": "pnpm seed && pnpm build && vercel build --prod && vercel deploy --prebuilt --prod"
  },
  "simple-git-hooks": {
    "pre-commit": "sh ./scripts/block-private.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/svelte": "^8.0.5",
    "@tailwindcss/vite": "^4.2.3",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "astro": "^6.1.8",
    "better-sqlite3": "^12.9.0",
    "sharp": "^0.34.5",
    "simple-git-hooks": "^2.13.1",
    "svelte": "^5.55.4",
    "tailwindcss": "^4.2.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vercel": "^52.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp",
      "simple-git-hooks"
    ]
  },
  "dependencies": {
    "html-to-image": "^1.11.13",
    "ts-fsrs": "^5.3.2"
  }
}
