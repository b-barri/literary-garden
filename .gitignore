# dependencies
node_modules/
.pnpm-store/

# build output
dist/
.astro/
.output/

# personal Kindle data — never commit
# raw: your vocab.db and clippings. processed: the derived JSON of your
# reading history. Either one makes this repo non-shareable if committed.
# public/covers/: downloaded book covers keyed by book id — they're public
# images in themselves, but the *filenames* still reveal your reading list.
data/raw/
data/processed/
# public/covers/* (not public/covers/) so we can re-include subdirs via
# the pattern below — gitignore can't re-include files if the parent
# directory itself is ignored.
public/covers/*
# Exception: the 4 botanical placeholder JPGs must ship with the template
# (coverFallback.ts references /covers/placeholders/N.jpg for books that
# don't resolve on Open Library or Google Books). Without these, every
# cloner with a sideloaded/obscure book sees broken tiles in the garden.
!public/covers/placeholders/
vocabulary/
*.kfx
*.azw*

# Kindle clippings metadata (.sdr sidecar dirs) and sideloaded book covers.
# Same rationale as data/raw/: filenames alone reveal reading history.
My Clippings.sdr/
*.sdr/
book_cover/

# Owner-specific config (copied from site.config.example.ts locally).
# Template ships the .example only; owner's real values stay out of git.
src/site.config.ts

# Owner-specific personal stamp image. Template ships the generic
# /public/stamp-default.svg as fallback.
public/bhavya-stamp.png
public/*-stamp.png

# Vercel project metadata — created by `vercel link`. Contains deployment
# IDs + project org, not secrets or data, but no reason to commit.
.vercel/

# environment
.env
.env.*
!.env.example

# macOS
.DS_Store

# editor + logs
.vscode/
.idea/
.claude/
*.log
excalidraw.log

# test artifacts
coverage/
playwright-report/
test-results/
